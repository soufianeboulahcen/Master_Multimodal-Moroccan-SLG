# ── Extracted keypoints (regenerated by the pipeline) ────────────────────────
data/processed/

# ── Training artefacts (checkpoints, logs) ───────────────────────────────────
runs/

# ── Intermediate generation directories (content copied to outputs/videos/demo/) ──
openpose_output/

# ── Raw dataset videos (download separately from Mendeley) ──────────────────
data/vedios-dataset/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key

# ── Loose artefacts generated in repo root (canonical copies live in images/) ─
# Ignore root-level PNGs/GIFs — they are notebook side-effects, not source files.
# The organised copies in images/ ARE tracked.
/*.png
/*.gif

# ── Intermediate generation directories ──────────────────────────────────────
demo_output/
outputs/figures/

# ── Temp / backup files ───────────────────────────────────────────────────────
*.tmp
*.bak
